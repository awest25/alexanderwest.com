{
  "name": "alexanderwest.com",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "build:html": "node scripts/build.mjs",
    "build": "npm run build:html && npm run build:css",
    "watch:css": "tailwindcss -i src/styles.css -o dist/styles.css --watch",
    "serve": "npx -y -p http-server@14 http-server dist -p 3000 -c-1"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^16.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "shiki": "^4.1.0",
    "tailwindcss": "^4.1.0"
  }
}
